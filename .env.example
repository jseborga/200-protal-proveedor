# ═══════════════════════════════════════════════════════════
# APU Marketplace — Variables de Entorno
# Copiar a .env y llenar los valores reales
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
APP_NAME=APU Marketplace
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=cambiar-esto-por-una-clave-segura-larga-aleatoria
APP_URL=https://marketplace.ingenieria.com.bo
CORS_ORIGINS=["https://marketplace.ingenieria.com.bo","http://localhost:3000"]

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://apu_mkt:password@db:5432/apu_marketplace
# Para EasyPanel: usar la URL interna del servicio postgres
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres-service:5432/dbname

# ── JWT Auth ─────────────────────────────────────────────
JWT_SECRET_KEY=cambiar-esto-por-otra-clave-segura
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── API Keys ─────────────────────────────────────────────
# Key maestra para admin (generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_API_KEY=

# ── AI Extraction ────────────────────────────────────────
AI_PROVIDER=openrouter
AI_API_KEY=
AI_MODEL=
# Proveedores soportados: openrouter, openai, anthropic, gemini
# OpenRouter: https://openrouter.ai/keys
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/settings/keys
# Gemini: https://aistudio.google.com/apikey

# ── WhatsApp (Evolution API) ─────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=apu-marketplace
# Evolution API se despliega como servicio en EasyPanel
# Docs: https://doc.evolution-api.com

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Crear bot: https://t.me/BotFather

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ingenieria.com.bo
SMTP_TLS=true

# ── GitHub (CI/CD) ───────────────────────────────────────
# Solo para referencia, no se usa en runtime
# GITHUB_REPO=tu-usuario/200-portal-proveedor
# GITHUB_TOKEN=ghp_...

# ── EasyPanel ────────────────────────────────────────────
# Configurar en EasyPanel UI > Environment Variables
# Todas las variables de arriba se configuran ahi para produccion
# EASYPANEL_PROJECT=apu-marketplace
# EASYPANEL_DOMAIN=marketplace.ingenieria.com.bo
